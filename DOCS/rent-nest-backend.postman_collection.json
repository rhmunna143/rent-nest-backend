          "name": "landloard get rental requests",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{devBaseUrl}}/api/landlord/requests",
              "host": ["{{devBaseUrl}}"],
              "path": ["api", "landlord", "requests"],
              "query": [
                {
                  "key": "status",
                  "value": "PENDING",
                  "description": "PENDING | APPROVED | REJECTED | ACTIVE | COMPLETED",
                  "disabled": true
                }
              ]
            },
            "description": "LANDLORD only. Requests on own properties with tenant contact info."
          },
          "response": []
        },
        {
          "name": "landloard update rental requests status",
          "request": {
            "method": "PATCH",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"status\": \"APPROVED\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{devBaseUrl}}/api/landlord/requests/24a6208d-2299-473a-8f8f-7fe917c37ba1",
              "host": ["{{devBaseUrl}}"],
              "path": ["api", "landlord", "requests", "24a6208d-2299-473a-8f8f-7fe917c37ba1"]
            },
            "description": "LANDLORD only (own property). APPROVED/REJECTED require the request to be PENDING; COMPLETED requires ACTIVE (paid) and frees the property. ACTIVE is set only by the Stripe webhook."
          },
          "response": []
        }
      ]
    },
    {
      "name": "payment",
      "item": [
        {
          "name": "create checkout session",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"rentalRequestId\": \"24a6208d-2299-473a-8f8f-7fe917c37ba1\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{devBaseUrl}}/api/payments/create",
              "host": ["{{devBaseUrl}}"],
              "path": ["api", "payments", "create"]
            },
            "description": "TENANT only (own request, status APPROVED). Returns `checkoutUrl` — open it in a browser and pay with Stripe test card 4242 4242 4242 4242 (any future expiry / any CVC). Already paid → 409."
          },
          "response": []
        },
        {
          "name": "get payment history",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{devBaseUrl}}/api/payments",
              "host": ["{{devBaseUrl}}"],
              "path": ["api", "payments"]
            },
            "description": "TENANT only. Own payments with status (PENDING | COMPLETED | FAILED), transaction id, and rental/property summary."
          },
          "response": []
        },
        {
          "name": "get single payment",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{devBaseUrl}}/api/payments/9a1f0d2e-0000-0000-0000-000000000000",
              "host": ["{{devBaseUrl}}"],
              "path": ["api", "payments", "9a1f0d2e-0000-0000-0000-000000000000"]
            },
            "description": "TENANT only (own payment)."
          },
          "response": []
        },
        {
          "name": "stripe webhook (called by Stripe)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "stripe-signature",
                "value": "t=timestamp,v1=signature",
                "description": "Set automatically by Stripe — requests without a valid signature are rejected with 400."
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"id\": \"evt_xxx\",\r\n    \"type\": \"checkout.session.completed\",\r\n    \"data\": {\r\n        \"object\": {\r\n            \"id\": \"cs_test_xxx\",\r\n            \"object\": \"checkout.session\",\r\n            \"payment_intent\": \"pi_xxx\"\r\n        }\r\n    }\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{devBaseUrl}}/api/payments/webhook",
              "host": ["{{devBaseUrl}}"],
              "path": ["api", "payments", "webhook"]
            },
            "description": "Called by Stripe, not by clients — documented here for completeness. On `checkout.session.completed`: payment → COMPLETED, rental → ACTIVE, property → RENTED, other pending requests → REJECTED. For local testing run: `stripe listen --forward-to localhost:8080/api/payments/webhook`."
          },
          "response": []
        }
      ]
    },

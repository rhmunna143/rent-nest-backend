                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{devBaseUrl}}/api/rentals",
              "host": ["{{devBaseUrl}}"],
              "path": ["api", "rentals"]
            },
            "description": "TENANT only. Property must be AVAILABLE; duplicate pending request → 409. `message` and `moveInDate` are optional."
          },
          "response": []
        },

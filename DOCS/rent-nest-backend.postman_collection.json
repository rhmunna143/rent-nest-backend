      "item": [
        {
          "name": "create- rental-request",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"propertyId\": \"2353f6bf-b860-4d08-bb74-b549ffe986ec\",\r\n    \"message\": \"I would love to rent this place.\",\r\n    \"moveInDate\": \"2026-08-01\"\r\n}",

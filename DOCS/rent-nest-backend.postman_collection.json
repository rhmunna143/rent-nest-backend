              "raw": "{\r\n    \"name\": \"Munna\",\r\n    \"email\": \"rhmunna19@gmail.com\",\r\n    \"password\": \"User@123\",\r\n    \"role\": \"TENANT\",\r\n    \"phone\": \"01877255595\",\r\n    \"profileImage\": \"https://i.ibb.co.com/wF86M1VQ/my-dp.png\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{devBaseUrl}}/api/auth/register",
              "host": ["{{devBaseUrl}}"],

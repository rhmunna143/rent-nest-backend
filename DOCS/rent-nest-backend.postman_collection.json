                  "description": "PENDING | APPROVED | REJECTED | ACTIVE | COMPLETED",
                  "disabled": true
                }
              ]
            },
            "description": "TENANT only. Own request history with property and payment summaries."
          },
          "response": []
        },
        {
          "name": "tenant get single rentals request",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{devBaseUrl}}/api/rentals/24a6208d-2299-473a-8f8f-7fe917c37ba1",
              "host": ["{{devBaseUrl}}"],
              "path": ["api", "rentals", "24a6208d-2299-473a-8f8f-7fe917c37ba1"]
            },
            "description": "TENANT only (own request). Includes full payment record."
          },
          "response": []
        },

# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

PORT=8080
DATABASE_URL=postgresql://user:password@localhost:5432/rentnest
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_ACCESS_EXPIRES_IN=1d
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
JWT_REFRESH_EXPIRES_IN=30d

# Stripe (test mode) — from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
# From `stripe listen` locally or the dashboard webhook endpoint config
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Where Stripe Checkout redirects after payment (defaults to the API's own pages)
PAYMENT_SUCCESS_URL=http://localhost:8080/payment-success
PAYMENT_CANCEL_URL=http://localhost:8080/payment-cancel
